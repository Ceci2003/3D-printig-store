---
import Layout from '../components/Layout.astro';
import SectionTitle from '../components/SectionTitle.astro';
import ProductCarousel from '../components/ProductCarousel.astro';
import HowItWorks from '../components/HowItWorks.astro';
import ServiceCard from '../components/ServiceCard.astro';
import { getCollection, getEntry } from 'astro:content';

let settings = null;
try {
  settings = (await getEntry('site', 'settings')).data;
} catch (e) {
  // Settings not found, use defaults
}
const products = await getCollection('products', ({ data }) => data.status === 'active');
const featuredProducts = products
  .filter(p => p.data.isTop || p.data.featured || p.data.isNew)
  .slice(0, 8);
---

<Layout title={`${settings?.siteName || '3D Print Studio'} - Начало`}>

  <!-- Hero Section -->
  <section class="relative text-white py-16 md:py-24 overflow-hidden">
    <!-- Background Image & Overlays -->
    <div class="absolute inset-0">
      <img src="/images/hero-bg.png" alt="Working 3D Printer" class="w-full h-full object-cover object-center" />
      <div class="absolute inset-0 bg-gradient-to-br from-blue-900/85 via-blue-800/75 to-indigo-900/85 mix-blend-multiply"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-blue-900/40 via-transparent to-blue-900/70"></div>
    </div>
    
    <!-- Subtle Pattern Background (3D printing grid pattern) -->
    <div 
      class="absolute inset-0 opacity-[0.15]"
      style="background-image: 
        linear-gradient(rgba(255,255,255,0.1) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.1) 1px, transparent 1px);
        background-size: 50px 50px;
        filter: blur(0.5px);"
    ></div>
    
    <!-- Subtle Grain Effect -->
    <div 
      class="absolute inset-0 opacity-[0.03] pointer-events-none"
      style="background-image: url('data:image/svg+xml,%3Csvg viewBox=\'0 0 400 400\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cfilter id=\'noiseFilter\'%3E%3CfeTurbulence type=\'fractalNoise\' baseFrequency=\'0.9\' numOctaves=\'4\' stitchTiles=\'stitch\'/%3E%3C/filter%3E%3Crect width=\'100%25\' height=\'100%25\' filter=\'url(%23noiseFilter)\'/%3E%3C/svg%3E');"
    ></div>
    
    <!-- Content -->
    <div class="container mx-auto px-4 relative z-10">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl md:text-6xl font-extrabold mb-6 tracking-tight drop-shadow-lg">
          {settings?.siteName || '3D Print Studio'}
        </h1>
        <p class="text-xl md:text-2xl mb-12 text-blue-50 font-light leading-relaxed drop-shadow-md">
          {settings?.brandTagline || 'Вашият партньор за 3D печат и дизайн'}
        </p>
        
        <!-- Two Panels -->
        <div class="grid md:grid-cols-2 gap-6 mt-16">
          <!-- Products Card -->
          <div class="group relative bg-white/15 backdrop-blur-md rounded-xl p-6 border border-white/20 overflow-hidden transition-all duration-300 hover:scale-[1.02] hover:shadow-2xl hover:shadow-blue-900/50">
            <!-- Card Background Pattern (Products - 3D objects pattern) -->
            <div 
              class="absolute inset-0 opacity-[0.12]"
              style="background-image: 
                radial-gradient(circle at 20% 30%, rgba(255,255,255,0.3) 2px, transparent 2px),
                radial-gradient(circle at 80% 70%, rgba(255,255,255,0.3) 2px, transparent 2px),
                radial-gradient(circle at 50% 50%, rgba(255,255,255,0.2) 1px, transparent 1px);
                background-size: 60px 60px, 80px 80px, 40px 40px;
                background-position: 0 0, 20px 20px, 10px 10px;"
            ></div>
            
            <!-- Gradient Overlay -->
            <div class="absolute inset-0 bg-gradient-to-br from-blue-600/30 via-purple-600/20 to-blue-800/40"></div>
            
            <!-- Content -->
            <div class="relative z-10">
              <h2 class="text-2xl font-bold mb-4 text-white drop-shadow-md">Продукти</h2>
              <ul class="text-left space-y-2 mb-6 text-blue-50">
                <li>• Персонализирани фигурки и подаръци</li>
                <li>• Готови продукти за всекидневна употреба</li>
                <li>• Сезонни и специални колекции</li>
              </ul>
              <a
                href="/products"
                class="inline-block bg-white text-blue-600 px-6 py-3 rounded-lg font-semibold hover:bg-blue-50 focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-transparent transition shadow-lg hover:shadow-xl"
              >
                Виж продуктите
              </a>
            </div>
          </div>
          
          <!-- Services Card -->
          <div class="group relative bg-white/15 backdrop-blur-md rounded-xl p-6 border border-white/20 overflow-hidden transition-all duration-300 hover:scale-[1.02] hover:shadow-2xl hover:shadow-blue-900/50">
            <!-- Card Background Pattern (Services - 3D printer/CAD pattern) -->
            <div 
              class="absolute inset-0 opacity-[0.12]"
              style="background-image: 
                repeating-linear-gradient(45deg, transparent, transparent 10px, rgba(255,255,255,0.1) 10px, rgba(255,255,255,0.1) 20px),
                repeating-linear-gradient(-45deg, transparent, transparent 10px, rgba(255,255,255,0.08) 10px, rgba(255,255,255,0.08) 20px);
                background-size: 40px 40px;"
            ></div>
            
            <!-- Gradient Overlay -->
            <div class="absolute inset-0 bg-gradient-to-br from-cyan-600/30 via-blue-600/20 to-indigo-800/40"></div>
            
            <!-- Content -->
            <div class="relative z-10">
              <h2 class="text-2xl font-bold mb-4 text-white drop-shadow-md">Услуги</h2>
              <ul class="text-left space-y-2 mb-6 text-blue-50">
                <li>• 3D печат по поръчка</li>
                <li>• Дизайн и моделиране</li>
                <li>• 3D сканиране</li>
              </ul>
              <a
                href="/services"
                class="inline-block bg-white text-blue-600 px-6 py-3 rounded-lg font-semibold hover:bg-blue-50 focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-transparent transition shadow-lg hover:shadow-xl"
              >
                Виж услугите
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Top/New Products -->
  <!-- <ProductCarousel 
    products={featuredProducts}
    id="top-products"
    title="Топ продукти"
    subtitle="Най-популярните и нови продукти"
  /> -->

  <!-- How It Works -->
  <HowItWorks defaultTab="products" />

  <!-- Mini Gallery Products -->
  <section class="py-12 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-8">
        <h2 class="text-3xl font-bold mb-4">Нашите продукти</h2>
        <p class="text-gray-600 max-w-2xl mx-auto mb-6">
          Открийте широк спектър от 3D печатни продукти - от персонализирани подаръци до функционални части.
        </p>
        <a
          href="/products"
          class="inline-block bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition"
        >
          Виж всички продукти
        </a>
      </div>
    </div>
  </section>

  <!-- Mini Gallery Services -->
  <section class="py-12 bg-gray-50">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold mb-4">Нашите услуги</h2>
        <p class="text-gray-600 max-w-2xl mx-auto">
          Професионални 3D услуги за всеки ваши проект - от дизайн до готов продукт
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <ServiceCard
          title="3D Печат"
          description="Професионален 3D печат с различни материали и технологии. Високо качество и прецизност за всеки проект."
          imageSrc="/images/services/3d-printing.png"
          imageAlt="3D принтер в действие с разноцветни материали"
          href="/services#printing"
        />
        <ServiceCard
          title="Дизайн"
          description="Създаване на 3D модели и персонализирани дизайни. Превръщаме вашите идеи в готови за печат модели."
          imageSrc="/images/services/3d-design.png"
          imageAlt="3D моделиране и дизайн на компютър"
          href="/services#design"
        />
        <ServiceCard
          title="3D Сканиране"
          description="Прецизно 3D сканиране на обекти за репликация или анализ. Високо детайлни резултати за всеки обект."
          imageSrc="/images/services/3d-scanning.png"
          imageAlt="3D сканиране на обект с професионален скенер"
          href="/services#scanning"
        />
      </div>
    </div>
  </section>

  <!-- Trust/Benefits -->
  <section class="py-12 bg-white">
    <div class="container mx-auto px-4">
      <div class="grid md:grid-cols-4 gap-6">
        <div class="text-center">
          <div class="text-4xl mb-4">⚡</div>
          <h3 class="font-bold mb-2">{settings?.turnaroundText || 'Обикновено 1–5 дни'}</h3>
          <p class="text-gray-600 text-sm">Бърза изработка</p>
        </div>
        <div class="text-center">
          <div class="text-4xl mb-4">👁️</div>
          <h3 class="font-bold mb-2">Преглед преди плащане</h3>
          <p class="text-gray-600 text-sm">Увереност в качеството</p>
        </div>
        <div class="text-center">
          <div class="text-4xl mb-4">✓</div>
          <h3 class="font-bold mb-2">Гаранция</h3>
          <p class="text-gray-600 text-sm">Гарантирано качество</p>
        </div>
        <div class="text-center">
          <div class="text-4xl mb-4">🚚</div>
          <h3 class="font-bold mb-2">Куриери</h3>
          <p class="text-gray-600 text-sm">{settings?.couriers?.join(', ') || 'Еконт, Спиди, Рапидо'}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact CTA -->
  <section class="py-16 bg-blue-600 text-white">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Готови да започнем?</h2>
      <p class="text-xl mb-8 text-blue-100">Свържете се с нас за безплатна консултация</p>
      <a
        href="/contacts"
        class="inline-block bg-white text-blue-600 px-8 py-4 rounded-lg font-semibold text-lg hover:bg-blue-50 focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-blue-600 transition"
      >
        Свържи се с нас
      </a>
    </div>
  </section>
</Layout>

